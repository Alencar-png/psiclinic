# ---------- App ----------
APP_NAME=PsiClinic
APP_ENV=dev
API_PREFIX=/api

# ---------- Database ----------
DATABASE_URL=postgresql+psycopg://psiclinic:psiclinic@localhost:5432/psiclinic

# ---------- Auth ----------
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-64-bytes-of-randomness
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# ---------- Crypto ----------
# Gere com:
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
MASTER_ENCRYPTION_KEY_B64=
ENCRYPTION_KEY_VERSION=1

# ---------- Clinical rules ----------
SESSION_LOCK_AFTER_DAYS=7
DEFAULT_DATA_RETENTION_DAYS=7300        # 20 anos (CFM 1.638/2002)

# ---------- 2FA ----------
TOTP_ISSUER=PsiClinic
REQUIRE_2FA_FOR_DOCTORS=false           # ativar em produção

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000

# ---------- Storage ----------
STORAGE_BACKEND=local
STORAGE_BUCKET=psiclinic-attachments
STORAGE_LOCAL_PATH=./var/attachments
